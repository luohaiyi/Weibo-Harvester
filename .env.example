# ============================================================
# WeiboHarvester — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改 .env 中标记为 🔴 的值（必填）
#   3. .env 文件不会被提交到 Git（已在 .gitignore 中排除）
#
# ⚠️ 安全警告：
#   - 请勿将真实的 .env 文件提交到版本控制系统
#   - 生产环境务必设置强随机 FLASK_SECRET_KEY
#   - 生产环境建议启用 API_TOKEN 访问认证
#   - MYSQL_PASSWORD（如需使用 MySQL 输出请填写密码）
# ============================================================

# ── 多容器部署配置（桥接网络模式）─────────────────────────────
# Docker Compose 项目名称（可选）
# 不设置则默认使用项目目录名，设置后可避免与同名项目冲突
# 注意：必须使用小写字母、数字、下划线或连字符
COMPOSE_PROJECT_NAME=weibo_harvester

# ── Flask 服务配置 ────────────────────────────────────────────
# Flask 监听地址（容器内监听所有网卡即可，一般无需修改）
FLASK_HOST=0.0.0.0
# 🔴 Flask 服务端口
# 修改后会影响：compose 端口映射、healthcheck、GUI 入口 URL
FLASK_PORT=5100
# Flask 调试模式（开发: 1 / 生产: 0）
FLASK_DEBUG=0
# Flask 运行环境（development 或 production）
FLASK_ENV=production
# Python 输出不缓冲（设为 1 以实时查看日志）
PYTHONUNBUFFERED=1

# ── Flask 安全配置（生产环境必填）──────────────────────────────
# Flask 会话签名密钥，用于 Session 加密
# 生成方式：openssl rand -hex 32  或  python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# API 访问令牌，设置为非空值后所有 /api/crawler/* 接口需要 X-API-Token 请求头
# 留空则禁用 API 认证（不推荐用于公网部署）
API_TOKEN=

# ── 微博 Cookie 配置 ──────────────────────────────────────────
# 微博登录凭证，通过 GUI 前端页面 http://localhost:5100 设置后自动注入
# 也可以在此手动填写（优先级低于 GUI 前端设置）
WEIBO_COOKIE=

# ── 时区配置 ──────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── MySQL 数据库配置 ──────────────────────────────────────────
# MySQL root 密码（仅在使用 --profile mysql 或 --profile db 时需要）
MYSQL_PASSWORD=weibo_harvester_password
# MySQL 主机名（Docker 网络内服务名，一般无需修改）
MYSQL_HOST=weibo-mysql
# MySQL 端口（容器内部端口，一般无需修改）
MYSQL_PORT=3306
# MySQL 用户名
MYSQL_USER=root
# MySQL 数据库名
MYSQL_DATABASE=weibo_harvester
# MySQL 宿主机端口映射（修改后外部可通过此端口连接 MySQL）
MYSQL_EXTERNAL_PORT=3306

# ── MongoDB 数据库配置 ────────────────────────────────────────
# MongoDB 连接串（Docker 网络内地址，一般无需修改）
MONGODB_URI=mongodb://weibo-mongo:27017/
# MongoDB 宿主机端口映射（修改后外部可通过此端口连接 MongoDB）
MONGO_EXTERNAL_PORT=27017

# ── SQLite 数据目录 ───────────────────────────────────────────
# SQLite 数据库文件存储目录（容器内路径，一般无需修改）
SQLITE_DATA_DIR=/app/data/sqlite

# ── 日志配置 ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 反封禁策略（平衡模式默认值）───────────────────────────────
ANTI_BAN_ENABLED=true
MAX_WEIBO_PER_SESSION=500
BATCH_SIZE=50
BATCH_DELAY=30
REQUEST_DELAY_MIN=8
REQUEST_DELAY_MAX=15
MAX_SESSION_TIME=600
MAX_API_ERRORS=5
REST_TIME_MIN=180

# ── 输出配置 ──────────────────────────────────────────────────
WRITE_MODE=csv,json
OUTPUT_DIRECTORY=/app/data

# ── 爬虫超时配置 ──────────────────────────────────────────────
# 爬虫最大运行时间（秒），默认 86400（24 小时）
MAX_CRAWLER_RUNTIME=86400

