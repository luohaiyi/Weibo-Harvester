# ============================================================
# WeiboHarvester — .gitignore
# 微博数据采集平台忽略规则
# ============================================================

# ── 运行时目录（爬取数据 / 日志 / 临时文件）──────────────────
# 这些目录由容器运行时生成，不应提交到版本控制
/data/
/logs/
/temp/

# 保留目录占位符（.gitkeep）
!*/.gitkeep
!**/.gitkeep

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.egg

# 编译的字节码缓存（JetBrains IDE）
*.pyc
__pycache__/

# ── 虚拟环境 ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 环境变量 / 密钥 ───────────────────────────────────────────
# 敏感配置绝不提交！
.env
.env.*
*.env
!.env.example

# ── 数据库文件 ─────────────────────────────────────────────────
# SQLite 数据库（用户数据）
*.db
*.sqlite
*.sqlite3
data/sqlite/

# ── IDE / 编辑器 ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── 测试 / 覆盖率 ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── Scrapy ───────────────────────────────────────────────────
.scrapy/

# ── Docker ───────────────────────────────────────────────────
# .dockerignore 已单独维护
.dockerignore
# docker-compose 配置文件（本地环境差异大，不纳入版本控制）
docker-compose.yml

# ── 构建产物 ───────────────────────────────────────────────────
*.tar
*.tar.gz
*.zip
dist/
*.log

# ── CodeBuddy AI 助手 ─────────────────────────────────────────
.codebuddy/

# ── 上游原始代码（不提交）─────────────────────────────────────
# 原始 dataabc 源码从外部获取，不纳入版本控制
tools/dataabc/original/

# ── 压缩包（工具自带）──────────────────────────────────────────
tools/*.zip
tools/dataabc/*.zip

# ── 隐藏文件（系统文件）────────────────────────────────────────
.*
!.gitignore
!.dockerignore
!.env.example
!.README.md
